# --- Server ---
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# --- Database (MySQL via Sequelize + mysql2) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=book_exam_store
DB_USER=root
DB_PASSWORD=changeme

# --- JWT ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_COOKIE_NAME=token

# --- Rate limiting (per IP) ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# --- Payments: Vodacom M-Pesa Tanzania (Open API) ---
MPESA_ENV=sandbox
MPESA_BASE_URL=https://openapi.m-pesa.com/sandbox/ipg/v2/vodafoneTZN
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_SERVICE_PROVIDER_CODE=
# Long random string only you and Vodacom know. Vodacom's dashboard doesn't
# let you set a header, so it's appended to the callback URL as ?secret=...
MPESA_CALLBACK_SECRET=replace_with_a_long_random_string
MPESA_CALLBACK_URL=${APP_BASE_URL}/api/payments/callback/mpesa?secret=${MPESA_CALLBACK_SECRET}

# --- Payments: Mixx by Yas (Tigo Pesa / MixByYas Collections API) ---
MIXBYYAS_ENV=sandbox
MIXBYYAS_BASE_URL=https://sandbox-api.mixbyyas.co.tz
MIXBYYAS_CLIENT_ID=
MIXBYYAS_CLIENT_SECRET=
MIXBYYAS_ACCOUNT_MSISDN=
MIXBYYAS_CALLBACK_SECRET=replace_with_a_different_long_random_string
MIXBYYAS_CALLBACK_URL=${APP_BASE_URL}/api/payments/callback/mixbyyas?secret=${MIXBYYAS_CALLBACK_SECRET}

# --- Uploads ---
MAX_UPLOAD_MB=50
