extends layout

block content
  .admin-toolbar
    input.search-box#searchBox(type="text" placeholder="Search books by title...")
    a.btn.btn-primary(href="/admin/books/new") + Upload Book

  .table-wrap
    table.table#booksTable
      thead
        tr
          th Cover
          th Title
          th Category
          th Price
          th Rent
          th Status
          th
      tbody
        tr
          td(colspan="7") Loading...
  #booksPagination.pagination-wrap

block scripts
  script.
    let currentPage = 1;
    let searchTimeout = null;

    async function loadBooks(page) {
      currentPage = page || 1;
      const q = document.getElementById('searchBox').value.trim();
      const params = new URLSearchParams({ page: currentPage, limit: 10 });
      if (q) params.set('q', q);

      const res = await fetch('/api/admin/books?' + params.toString(), { credentials: 'include' });
      const data = await res.json();
      render(data.books || [], data.pagination);
    }

    function render(books, pagination) {
      const tbody = document.querySelector('#booksTable tbody');
      if (books.length === 0) {
        tbody.innerHTML = '<tr><td colspan="7">No books found.</td></tr>';
        renderPagination(document.getElementById('booksPagination'), null, () => {});
        return;
      }
      tbody.innerHTML = books.map(b => `
        <tr>
          <td>${b.coverImage ? `<img class="thumb" src="${b.coverImage}">` : `<div class="thumb-placeholder">📘</div>`}</td>
          <td>${b.title}</td>
          <td>${b.Category ? b.Category.name : '-'}</td>
          <td>TZS ${b.price}</td>
          <td>${b.rentPrice ? 'TZS ' + b.rentPrice : '-'}</td>
          <td><span class="status-pill ${b.isPublished ? 'status-published' : 'status-unpublished'}">${b.isPublished ? 'Published' : 'Hidden'}</span></td>
          <td class="row-actions">
            <a class="btn btn-small btn-secondary" href="/admin/books/${b.id}/edit">Edit</a>
            <button class="btn btn-small" data-toggle-pub="${b.id}" data-pub="${b.isPublished}">${b.isPublished ? 'Unpublish' : 'Publish'}</button>
            <button class="btn btn-small btn-danger" data-del-book="${b.id}">Delete</button>
          </td>
        </tr>
      `).join('');

      renderPagination(document.getElementById('booksPagination'), pagination, loadBooks);

      document.querySelectorAll('[data-del-book]').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm('Delete this book permanently? This cannot be undone.')) return;
          const res = await fetch(`/api/books/${btn.dataset.delBook}`, { method: 'DELETE', credentials: 'include' });
          const data = await res.json();
          if (!data.success) return alert(data.message || 'Could not delete book.');
          loadBooks(currentPage);
        });
      });

      document.querySelectorAll('[data-toggle-pub]').forEach(btn => {
        btn.addEventListener('click', async () => {
          const isPublished = btn.dataset.pub !== 'true';
          const fd = new FormData();
          fd.append('isPublished', isPublished);
          const res = await fetch(`/api/books/${btn.dataset.togglePub}`, { method: 'PUT', credentials: 'include', body: fd });
          const data = await res.json();
          if (!data.success) return alert(data.message || 'Could not update book.');
          loadBooks(currentPage);
        });
      });
    }

    document.getElementById('searchBox').addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => loadBooks(1), 350);
    });

    loadBooks(1);
