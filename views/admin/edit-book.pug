extends layout

block content
  form#editBookForm.form(enctype="multipart/form-data")
    .form-group
      label Title
      input#f_title(type="text" name="title" required)
    .form-group
      label Author
      input#f_author(type="text" name="author")
    .form-group
      label Category
      select#f_categoryId(name="categoryId" required)
        each cat in categories
          option(value=cat.id)= cat.name
    .form-group
      label Description
      textarea#f_description(name="description" rows="4")
    .form-group
      label Buy price (TZS)
      input#f_price(type="number" name="price" min="0" step="0.01" required)
    .form-group
      label Rent price (TZS, optional)
      input#f_rentPrice(type="number" name="rentPrice" min="0" step="0.01")
    .form-group
      label Rent duration (days)
      input#f_rentDurationDays(type="number" name="rentDurationDays" min="1")
    .form-group
      label
        input#f_isPublished(type="checkbox" name="isPublished" style="width:auto;display:inline-block;margin-right:8px;")
        | Published (visible to users)
    .form-group
      label Replace cover image (optional)
      input(type="file" name="cover" accept="image/*")
    .form-group
      label Replace resource file (optional — leave blank to keep current file)
      input(type="file" name="resource" accept=".pdf,.epub,.doc,.docx")
    p#editMsg.success-text
    .actions
      button.btn.btn-primary(type="submit") Save Changes
      a.btn.btn-secondary(href="/admin/books") Cancel

block scripts
  script.
    const bookId = #{bookId};

    async function loadBook() {
      const res = await fetch(`/api/admin/books/${bookId}`, { credentials: 'include' });
      const data = await res.json();
      if (!data.success) { document.getElementById('editMsg').textContent = data.message; return; }
      const b = data.book;
      document.getElementById('f_title').value = b.title || '';
      document.getElementById('f_author').value = b.author || '';
      document.getElementById('f_categoryId').value = b.categoryId;
      document.getElementById('f_description').value = b.description || '';
      document.getElementById('f_price').value = b.price;
      document.getElementById('f_rentPrice').value = b.rentPrice || '';
      document.getElementById('f_rentDurationDays').value = b.rentDurationDays || 30;
      document.getElementById('f_isPublished').checked = !!b.isPublished;
    }

    document.getElementById('editBookForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      fd.set('isPublished', document.getElementById('f_isPublished').checked);
      const res = await fetch(`/api/books/${bookId}`, { method: 'PUT', credentials: 'include', body: fd });
      const data = await res.json();
      const msg = document.getElementById('editMsg');
      if (data.success) {
        msg.textContent = 'Saved.';
        setTimeout(() => window.location.href = '/admin/books', 700);
      } else {
        msg.textContent = data.message || 'Could not save changes.';
      }
    });

    loadBook();
