doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Admin &middot; #{title || 'Tafuta Books & Exams'}
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet")
    link(href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0&display=block" rel="stylesheet")
    link(rel="stylesheet" href="/css/style.css")
    link(rel="stylesheet" href="/css/admin.css")
  body.admin-body
    aside.admin-sidebar
      a.admin-brand(href="/admin")
        span.brand-mark A
        span Admin Panel
      nav.admin-nav
        a(href="/admin" class=(active === 'dashboard' ? 'active' : ''))
          span.material-symbols-outlined dashboard
          span Dashboard
        a(href="/admin/books" class=(active === 'books' ? 'active' : ''))
          span.material-symbols-outlined menu_book
          span Books
        a(href="/admin/exams" class=(active === 'exams' ? 'active' : ''))
          span.material-symbols-outlined quiz
          span Past Papers
        a(href="/admin/categories" class=(active === 'categories' ? 'active' : ''))
          span.material-symbols-outlined category
          span Categories
        a(href="/admin/transactions" class=(active === 'transactions' ? 'active' : ''))
          span.material-symbols-outlined payments
          span Transactions
        a(href="/admin/users" class=(active === 'users' ? 'active' : ''))
          span.material-symbols-outlined group
          span Users
      .admin-sidebar-footer
        a(href="/")
          span.material-symbols-outlined.inline-icon arrow_back
          | Back to site
        a#adminLogoutBtn(href="#")
          span.material-symbols-outlined.inline-icon logout
          | Logout

    main.admin-main
      header.admin-topbar
        h1= title || 'Dashboard'
        span.admin-user= user ? ('Signed in as ' + user.name) : ''
      .admin-content
        block content

    //- Mobile-only floating bottom dock — replaces the sidebar on small screens
    nav.admin-dock
      .admin-dock-glow
      a.admin-dock-item(href="/admin" data-path="/admin" class=(active === 'dashboard' ? 'active' : ''))
        span.admin-dock-icon
          span.material-symbols-outlined dashboard
        span.admin-dock-label Home
      a.admin-dock-item(href="/admin/books" data-path="/admin/books" class=(active === 'books' ? 'active' : ''))
        span.admin-dock-icon
          span.material-symbols-outlined menu_book
        span.admin-dock-label Books
      a.admin-dock-item(href="/admin/exams" data-path="/admin/exams" class=(active === 'exams' ? 'active' : ''))
        span.admin-dock-icon
          span.material-symbols-outlined quiz
        span.admin-dock-label Papers
      a.admin-dock-item(href="/admin/transactions" data-path="/admin/transactions" class=(active === 'transactions' ? 'active' : ''))
        span.admin-dock-icon
          span.material-symbols-outlined payments
        span.admin-dock-label Sales
      button.admin-dock-item#adminMoreBtn(type="button")
        span.admin-dock-icon
          span.material-symbols-outlined apps
        span.admin-dock-label More
      button.admin-dock-item.admin-dock-logout#adminDockLogout(type="button")
        span.admin-dock-icon
          span.material-symbols-outlined logout
        span.admin-dock-label Logout

    //- "More" sheet — reaches Categories / Users without crowding the dock
    .admin-more-sheet#adminMoreSheet
      .admin-more-sheet-inner
        .admin-more-sheet-handle
        a(href="/admin/categories")
          span.material-symbols-outlined category
          | Categories
        a(href="/admin/users")
          span.material-symbols-outlined group
          | Users
        a(href="/")
          span.material-symbols-outlined storefront
          | Back to site
        button.admin-more-close#adminMoreClose(type="button") Close

    script(src="/js/main.js")
    script.
      function adminLogout(e) {
        if (e) e.preventDefault();
        fetch('/api/auth/logout', { method: 'POST', credentials: 'include' })
          .then(function () { window.location.href = '/'; });
      }
      var lb = document.getElementById('adminLogoutBtn');
      if (lb) lb.addEventListener('click', adminLogout);
      var dockLogout = document.getElementById('adminDockLogout');
      if (dockLogout) dockLogout.addEventListener('click', adminLogout);

      var moreBtn = document.getElementById('adminMoreBtn');
      var moreSheet = document.getElementById('adminMoreSheet');
      var moreClose = document.getElementById('adminMoreClose');
      if (moreBtn && moreSheet) {
        moreBtn.addEventListener('click', function () { moreSheet.classList.add('open'); });
        moreSheet.addEventListener('click', function (e) { if (e.target === moreSheet) moreSheet.classList.remove('open'); });
        if (moreClose) moreClose.addEventListener('click', function () { moreSheet.classList.remove('open'); });
      }
    block scripts
