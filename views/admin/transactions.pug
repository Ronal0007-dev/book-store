extends layout

block content
  .admin-toolbar
    input.search-box#searchBox(type="text" placeholder="Search by user, email or order #...")

  .table-wrap
    table.table#txTable
      thead
        tr
          th Order
          th User
          th Provider
          th Phone
          th Amount
          th Status
          th Date
          th
      tbody
        tr
          td(colspan="8") Loading...
  #txPagination.pagination-wrap

block scripts
  script.
    let currentPage = 1;
    let searchTimeout = null;

    async function loadTransactions(page) {
      currentPage = page || 1;
      const q = document.getElementById('searchBox').value.trim();
      const params = new URLSearchParams({ page: currentPage, limit: 10 });
      if (q) params.set('q', q);

      const res = await fetch('/api/admin/transactions?' + params.toString(), { credentials: 'include' });
      const data = await res.json();
      render(data.payments || [], data.pagination);
    }

    function render(payments, pagination) {
      const tbody = document.querySelector('#txTable tbody');
      if (payments.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8">No transactions found.</td></tr>';
        renderPagination(document.getElementById('txPagination'), null, () => {});
        return;
      }
      tbody.innerHTML = payments.map(p => `
        <tr>
          <td>${p.Order ? p.Order.orderNumber : '-'}</td>
          <td>${p.User ? p.User.name + ' (' + p.User.email + ')' : '-'}</td>
          <td>${p.provider}</td>
          <td>${p.phone}</td>
          <td>TZS ${p.amount}</td>
          <td>
            <select class="status-select" data-id="${p.id}">
              ${['initiated','pending','success','failed'].map(s => `<option value="${s}" ${s === p.status ? 'selected' : ''}>${s}</option>`).join('')}
            </select>
          </td>
          <td>${new Date(p.createdAt).toLocaleString()}</td>
          <td class="row-actions">
            <button class="btn btn-small btn-danger" data-del-tx="${p.id}">Delete</button>
          </td>
        </tr>
      `).join('');

      renderPagination(document.getElementById('txPagination'), pagination, loadTransactions);

      document.querySelectorAll('.status-select').forEach(sel => {
        sel.addEventListener('change', async () => {
          if (sel.value === 'success' && !confirm('Mark as SUCCESS? This will immediately grant the user access to everything in this order.')) {
            loadTransactions(currentPage);
            return;
          }
          const res = await fetch(`/api/admin/transactions/${sel.dataset.id}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ status: sel.value })
          });
          const data = await res.json();
          if (!data.success) { alert(data.message || 'Could not update.'); loadTransactions(currentPage); }
        });
      });

      document.querySelectorAll('[data-del-tx]').forEach(btn => {
        btn.addEventListener('click', async () => {
          if (!confirm('Delete this transaction record? This does not revoke any access already granted.')) return;
          await fetch(`/api/admin/transactions/${btn.dataset.delTx}`, { method: 'DELETE', credentials: 'include' });
          loadTransactions(currentPage);
        });
      });
    }

    document.getElementById('searchBox').addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => loadTransactions(1), 350);
    });

    loadTransactions(1);
