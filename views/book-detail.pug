extends layout

block content
  section.detail-section
    .detail-grid
      if book.coverImage
        img.cover-large(src=book.coverImage alt=book.title)
      else
        .cover-large-placeholder 📘
      .detail-info
        h1= book.title
        .detail-tags
          span.tag= book.Category ? book.Category.name : 'Book'
          if book.author
            span.tag by #{book.author}
        p= book.description || 'No description provided for this book.'
        p.price Buy: TZS #{book.price}
        if book.rentPrice
          p.price Rent (#{book.rentDurationDays} days): TZS #{book.rentPrice}

        if owned
          a.btn.btn-primary(href=`/api/books/${book.id}/download`) ⬇ Download / Open
        else
          .actions
            button.btn.btn-primary(data-add-cart data-type="book" data-id=book.id data-access="buy") Add to Cart — Buy
            if book.rentPrice
              button.btn.btn-secondary(data-add-cart data-type="book" data-id=book.id data-access="rent") Add to Cart — Rent
          p#addCartMsg.success-text
          p.muted 🔒 The file unlocks automatically the moment your M-Pesa / Mixx by Yas payment is confirmed.
