extends layout

block content
  section.auth-section
    h1 Forgot password
    p.muted Enter your account email and we'll send you a link to reset your password.
    form#forgotForm.form
      .form-group
        label(for="email") Email
        input#email(type="email" name="email" required)
      p#forgotMsg.success-text
      p#forgotError.error-text
      button.btn.btn-primary(type="submit") Send reset link
    p #[a(href="/login") Back to login]

block scripts
  script.
    document.getElementById('forgotForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = document.getElementById('email').value;
      const btn = e.target.querySelector('button');
      btn.disabled = true;
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      btn.disabled = false;
      if (data.success) {
        document.getElementById('forgotError').textContent = '';
        document.getElementById('forgotMsg').textContent = data.message;
        e.target.reset();
      } else {
        document.getElementById('forgotError').textContent = data.message || 'Something went wrong.';
      }
    });
