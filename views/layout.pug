            if user.role === 'admin' || user.role === 'superadmin'
              a(href="/admin") Admin
            a#logoutBtn.nav-btn(href="#") Logout
          else
            a(href="/login") Login
            a.nav-btn(href="/register") Sign Up Free

    .level-strip
      .level-strip-inner
        a(href="/exams") All Levels
        each cat in (navExamCategories || [])
          a(href=`/exams?categoryId=${cat.id}`)= cat.name
        a(href="/books") Textbooks

    main.container
      block content

    a.whatsapp-float(href="https://wa.me/255700000000" target="_blank" rel="noopener" title="Chat with us on WhatsApp") <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#18333C"><path d="M240-400h320v-80H240v80Zm0-120h480v-80H240v80Zm0-120h480v-4q-37-8-67.5-27.5T600-720H240v80ZM80-80v-720q0-33 23.5-56.5T160-880h404q-4 20-4 40t4 40H160v525l46-45h594v-324q23-5 43-13.5t37-22.5v360q0 33-23.5 56.5T800-240H240L80-80Zm80-720v480-480Zm515 45q-35-35-35-85t35-85q35-35 85-35t85 35q35 35 35 85t-35 85q-35 35-85 35t-85-35Z"/></svg>

    footer.footer
      .footer-inner
        .footer-col
          h4 Tafuta Books
          p Buy or rent textbooks and NECTA-style past papers online. Instant access after payment via M-Pesa or Mixx by Yas.
        .footer-col
          h4 Quick Links
          a(href="/books") Books
          a(href="/exams") Past Papers
          a(href="/register") Create Account
        .footer-col
          h4 Support
          a(href="tel:+255700000000") Call us
          a(href="https://wa.me/255700000000" target="_blank" rel="noopener") WhatsApp us
        .footer-col
          h4 We accept
          .payment-badges
            span.badge M-Pesa
            span.badge Mixx by Yas
      .footer-bottom
        p © #{new Date().getFullYear()} Tafuta Books &amp; Exams. Not affiliated with any EXAM Board. All papers &amp; books are for study purposes.

