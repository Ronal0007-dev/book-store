doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{title || 'Tafuta Books & Exams | Buy & Rent Books and Past Papers Online'}
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/css/style.css")
  body.has-mobile-nav
    .top-bar
      .top-bar-inner
        span 🇹🇿 Tanzania's marketplace for books &amp; past papers
        span.top-bar-right
          a(href="tel:+255700000000") ☎️ +255 700 000 000
          a(href="https://wa.me/255700000000" target="_blank" rel="noopener") WhatsApp

    header.navbar
      .navbar-inner
        a.brand(href="/")
          span.brand-mark T
          span.brand-text Tafuta
            span.brand-text-accent  Books 
              span.brand-text-accent-sub &amp; Exams
        form.nav-search(action="/search" method="GET")
          input(type="text" name="q" placeholder="Search books or past papers e.g. 'Stage 6 English'")
          button(type="submit") 
            svg(xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#f8fafd")
              path(d="M796-120 480-436q-28 28-66.5 43T320-360q-83 0-141.5-58.5T120-560q0-83 58.5-141.5T320-760q83 0 141.5 58.5T520-560q0 38-15 76t-43 66l316 316-56 56ZM320-440q61 0 103.5-42.5T466-560q0-61-42.5-103.5T320-706q-61 0-103.5 42.5T174-560q0 61 42.5 103.5T320-440Z")
        nav.nav-links
          a(href="/books") Books
          a(href="/exams") Past Papers
          if user
            a(href="/library") <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#75FB4C"><path d="M400-400h160v-80H400v80Zm0-120h320v-80H400v80Zm0-120h320v-80H400v80Zm-80 400q-33 0-56.5-23.5T240-320v-480q0-33 23.5-56.5T320-880h480q33 0 56.5 23.5T880-800v480q0 33-23.5 56.5T800-240H320Zm0-80h480v-480H320v480ZM160-80q-33 0-56.5-23.5T80-160v-560h80v560h560v80H160Zm160-720v480-480Z"/></svg> My Library
