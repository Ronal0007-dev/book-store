extends layout

block content
  section.auth-section
    h1 Reset password
    if !token || !email
      p.notice This reset link looks incomplete. Please request a new one from the #[a(href="/forgot-password") forgot password page].
    else
      form#resetForm.form
        input(type="hidden" id="token" value=token)
        input(type="hidden" id="email" value=email)
        .form-group
          label(for="password") New password
          input#password(type="password" minlength="6" required)
        .form-group
          label(for="confirmPassword") Confirm new password
          input#confirmPassword(type="password" minlength="6" required)
        p#resetError.error-text
        p#resetMsg.success-text
        button.btn.btn-primary(type="submit") Reset password

block scripts
  script.
    const form = document.getElementById('resetForm');
    if (form) form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      const errorEl = document.getElementById('resetError');
      const msgEl = document.getElementById('resetMsg');
      errorEl.textContent = '';
      msgEl.textContent = '';

      if (password !== confirmPassword) {
        errorEl.textContent = 'Passwords do not match.';
        return;
      }

      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: document.getElementById('email').value,
          token: document.getElementById('token').value,
          password
        })
      });
      const data = await res.json();
      if (data.success) {
        msgEl.textContent = data.message + ' Redirecting to login...';
        setTimeout(() => window.location.href = '/login', 1200);
      } else {
        errorEl.textContent = data.message || 'Could not reset password.';
      }
    });
